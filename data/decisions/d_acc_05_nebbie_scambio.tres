effetto = SubResource("eff_0")
feedback_testo = "Orm posa accanto alle ossa il nostro miglior coltello di selce e arretra. Al mattino è sparito, e al suo posto c'è un cerchio di pietre attorno al fuoco spento. Un patto, forse. O un avvertimento gentile."

