label_text = "Studia la pietra che trattiene la luce"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_2")
feedback_testo = "Lyssa tiene la pietra nel buio e ne guarda il chiarore spegnersi piano, come un respiro. \"Non è la luce del fuoco,\" sussurra. \"È la luce di qualcosa che ci sta guardando indietro.\""

[resource]
script = ExtResource("dec")
id = "d_acc_05_nebbie_scambio"
era = 1
testo_consigliere = "Il Popolo delle Nebbie ha lasciato altri doni sul muschio: ossa intagliate, e una pietra liscia che di notte sembra trattenere la luce. Aspettano sul limite del bosco, immobili. Non chiedono niente. Ed è proprio questo che mi gela. Come rispondiamo al loro silenzio?"
personaggio_id = "era1_kael"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "incontro"
