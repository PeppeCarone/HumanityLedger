effetto = SubResource("eff_1")
feedback_testo = "Kael li segue nella bruma per mezza notte. Torna più pallido del solito. \"Non accendono fuochi,\" dice soltanto. \"E cantano la nenia di Lyssa. Ma loro la sanno fino in fondo.\""

