oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Esigi un risarcimento senza spargere sangue"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_1")
feedback_testo = "Orm porta la lancia spezzata al loro accampamento e la pianta davanti all'anziano, in silenzio. Tornano tre ceste di pesce, e nessuna parola. Un affronto pagato non è un amico, ma non è più una ferita aperta."

