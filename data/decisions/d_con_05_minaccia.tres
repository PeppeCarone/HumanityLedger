effetto = SubResource("eff_0")
feedback_testo = "Brann guida un assalto notturno alle loro trappole e torna senza perdite, con due prigionieri e una storia da raccontare. Il popolo esulta. Tra i due clan, il fiume da stanotte scorre più stretto e più rosso."

