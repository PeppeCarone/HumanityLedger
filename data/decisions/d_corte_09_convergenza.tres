[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/voce.tres" id="s_voce"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_voce"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]

[sub_resource type="Resource" id="eff_accogli"]
script = ExtResource("eff")
stat_delta = {
"scienza": 10
}
set_flags = {
"voce_accolta": true
}
unlock_lore = ["lore_convergenza"]
unlock_eventi = ["voce_nel_bosco", "tempio_vuoto"]
add_decisione_chiave = "accolto_la_voce"
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_rifiuta"]
script = ExtResource("eff")
stat_delta = {
"legge": 8,
"popolo": 6
}
set_flags = {
"voce_rifiutata": true
}
unlock_lore = ["lore_voce_rifiutata"]
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_sigilla"]
script = ExtResource("eff")
stat_delta = {
"militare": 8,
"legge": 4
}
set_flags = {
"tempio_sigillato": true
}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_accogli"]
script = ExtResource("opt")
strategia = ExtResource("s_voce")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_voce")
label_text = "Accogli la Voce dentro di voi"
target_consigliere_id = "era2_iove"
effetto = SubResource("eff_accogli")
feedback_testo = "Iove apre il tempio e ascolta. Il popolo cambia in qualcosa che non si riconosce più del tutto come umano. L'era che verrà non ha ancora un nome."

[sub_resource type="Resource" id="opt_rifiuta"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Rifiutala, resta umano"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_rifiuta")
feedback_testo = "Maren chiude il tempio e le sue domande. Il popolo resta sé stesso: fragile, mortale, libero. La Voce tace, per ora."

[sub_resource type="Resource" id="opt_sigilla"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Sigillala con la forza"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_sigilla")
feedback_testo = "Calden mura il tempio e posta guardie. Ciò che dormiva lì sotto resta sepolto. Nessuno saprà mai cosa abbiamo rifiutato."

[resource]
script = ExtResource("dec")
id = "d_corte_09_convergenza"
era = 2
testo_consigliere = "Iove: la presenza che ci segue da ere è qui, nel tempio che nessuno ha costruito. Chiede solo di essere accolta. Cosa diventa il popolo dello spirito?"
personaggio_id = "era2_iove"
opzioni = [SubResource("opt_accogli"), SubResource("opt_rifiuta"), SubResource("opt_sigilla")]
tipo_decisione = "mistero"
