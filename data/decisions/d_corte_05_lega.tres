[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/ascia.tres" id="s_ascia"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/ascia.png" id="t_ascia"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]

[sub_resource type="Resource" id="eff_alleanza"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 10,
"tesoro": 8
}
set_flags = {}
unlock_lore = ["lore_lega_coste"]
add_decisione_chiave = "commercio_lega"
add_to_log = ""
rapporti_civilta = {
"lega_coste": 25
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_porto"]
script = ExtResource("eff")
stat_delta = {
"costruzione": 12,
"tesoro": 6
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"lega_coste": 8
}
popolazione_delta = 1

[sub_resource type="Resource" id="eff_dazi"]
script = ExtResource("eff")
stat_delta = {
"militare": 8,
"tesoro": 10
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"lega_coste": -20
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_alleanza"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Alleanza commerciale"
target_consigliere_id = "era2_sereth"
effetto = SubResource("eff_alleanza")
feedback_testo = "Sereth firma i patti della Lega. Le navi delle Coste portano ricchezza e voci da ogni mare."

[sub_resource type="Resource" id="opt_porto"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Costruire un porto"
target_consigliere_id = "era2_lena"
effetto = SubResource("eff_porto")
feedback_testo = "Lena scava un porto nella roccia della costa. La Lega attracca e il regno guarda finalmente al mare."

[sub_resource type="Resource" id="opt_dazi"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Imporre dazi armati"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_dazi")
feedback_testo = "Calden tassa ogni nave con le lance puntate. Le casse si riempiono, ma i mercanti della Lega imparano a temerci."

[resource]
script = ExtResource("dec")
id = "d_corte_05_lega"
era = 2
testo_consigliere = "Vorrik: la Lega delle Coste a ovest non vuole guerra, vuole guadagno. Mercanti, navi, oro. Possiamo farne alleati o vacche da mungere. Cosa decidiamo?"
personaggio_id = "era2_vorrik"
opzioni = [SubResource("opt_alleanza"), SubResource("opt_porto"), SubResource("opt_dazi")]
tipo_decisione = "incontro"
