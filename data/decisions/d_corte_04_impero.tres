effetto = SubResource("eff_infiltra")
feedback_testo = "Saekh fa entrare i suoi corvi nei palazzi del Sole. Tornano con segreti che valgono più di un esercito."

[resource]
script = ExtResource("dec")
id = "d_corte_04_impero"
era = 2
testo_consigliere = "L'emissario dell'Impero del Sole ha posato sul mio tavolo una bilancia d'oro, senza una parola: su un piatto l'elenco dei tributi, sull'altro niente. Alla loro corte si parla per gesti, e questo gesto dice: riempite il piatto, o verremo a riempirlo noi. Ma ho visto le crepe sotto la doratura - l'Impero è vasto, e stanco. Cosa rispondiamo a est?"
personaggio_id = "era2_sereth"
opzioni = [SubResource("opt_tributo"), SubResource("opt_sfida"), SubResource("opt_infiltra")]
tipo_decisione = "incontro"
illustrazione_id = "summit"
