effetto = SubResource("eff_tributo")
feedback_testo = "Sereth riempie i carri d'oro e li manda a est. L'Impero sorride e abbassa la spada. Per ora il regno respira."

[sub_resource type="Resource" id="opt_sfida"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Rifiuta e mostra le armi"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_sfida")
feedback_testo = "Calden rimanda l'emissario a mani vuote. L'Impero del Sole non dimentica gli affronti. La guerra è solo rimandata."

[sub_resource type="Resource" id="opt_infiltra"]
script = ExtResource("opt")
