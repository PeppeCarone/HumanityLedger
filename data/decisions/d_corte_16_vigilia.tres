[gd_resource type="Resource" script_class="Decision" load_steps=16 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Resource" path="res://data/strategie/economico.tres" id="s_economico"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/economico.png" id="t_economico"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]

[sub_resource type="Resource" id="eff_0"]
script = ExtResource("eff")
stat_delta = {
"militare": 13,
"tesoro": -3
}
set_flags = {}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Richiama ogni lancia e presidia i passi"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_0")
feedback_testo = "Calden richiama i veterani e mette guarnigioni su ogni valico. \"Le ferite peggiori,\" dice brusco, \"le ho viste su chi pensava di avere ancora tempo. Noi saremo già in piedi quando busseranno.\""

[sub_resource type="Resource" id="eff_1"]
script = ExtResource("eff")
stat_delta = {
"tesoro": 12,
"popolo": 2
}
set_flags = {}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_economico")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_economico")
label_text = "Riempi granai e casse fino all'orlo"
target_consigliere_id = "era2_vorrik"
effetto = SubResource("eff_1")
feedback_testo = "Vorrik compra, accumula, sigilla. Granai pieni, casse piene, debiti riscossi fino all'ultimo conio. \"Le guerre,\" dice freddo, \"le vince chi può permettersi di perderne un pezzo.\""

[sub_resource type="Resource" id="eff_2"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 12
}
set_flags = {}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"impero_sole": 4,
"lega_coste": 4
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_2"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Manda messi a ogni corte, anche nemica"
target_consigliere_id = "era2_sereth"
effetto = SubResource("eff_2")
feedback_testo = "Sereth spedisce messi in ogni direzione, con parole cucite su misura per ciascuna corte. \"Quando il temporale arriva,\" osserva, \"conviene che tutti ricordino di averci stretto la mano. Anche chi sperava di no.\""

[resource]
script = ExtResource("dec")
id = "d_corte_16_vigilia"
era = 2
testo_consigliere = "Lo sento come si sente un temporale dietro i monti. L'Impero arma le legioni, la Lega ritira le navi dai porti lontani, e le fonderie di Lena scaldano metalli giorno e notte. Qualunque strada il consiglio sceglierà, il regno deve arrivarci in piedi. Come usiamo il tempo che resta?"
personaggio_id = "era2_calden"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "proposta_consigliere"
