target_consigliere_id = "era2_karro"
effetto = SubResource("eff_1")
feedback_testo = "Karro scavalca la barricata da solo, a mani aperte, e si siede sul carro rovesciato. Parlano fino all'alba. Le fornaci si riaccendono: il regno ha piegato l'orgoglio, non la schiena."

