icona_drag = ExtResource("t_scudo")
label_text = "Sfonda le barricate prima dell'alba"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_0")
feedback_testo = "Le barricate cadono in un'ora. Calden conta i feriti a voce alta, uno per uno, perché il consiglio li senta. L'ordine è tornato: brucia ancora, ma è tornato."

