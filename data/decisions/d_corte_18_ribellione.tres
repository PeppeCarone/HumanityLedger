oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Processa i capi, grazia chi depone"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_2")
feedback_testo = "Maren istruisce il processo nella piazza stessa, davanti alle fornaci spente. Tre condanne, lette piano; per tutti gli altri, la grazia. La legge mostra prima il peso, poi la mano aperta."

[resource]
script = ExtResource("dec")
id = "d_corte_18_ribellione"
era = 2
testo_consigliere = "Il quartiere delle fornaci ha bruciato i registri delle tasse e rovesciato i carri alle porte. Barricate alte un uomo, e dietro gente che conosco per nome. Stanotte ho riportato due feriti miei e tre dei loro. Posso riprendermi le strade prima dell'alba, ma il prezzo lo decidete voi. Cosa facciamo della rivolta?"
personaggio_id = "era2_calden"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "catastrofe"
illustrazione_id = "rebellion"
