[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/ascia.tres" id="s_ascia"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/ascia.png" id="t_ascia"]

[sub_resource type="Resource" id="eff_guerra"]
script = ExtResource("eff")
stat_delta = {
"militare": 14,
"diplomazia": -6
}
set_flags = {
"guerra_impero": true
}
unlock_lore = ["lore_marcia_impero"]
add_decisione_chiave = "marciato_contro_impero"
add_to_log = ""
rapporti_civilta = {
"impero_sole": -40
}
popolazione_delta = -2

[sub_resource type="Resource" id="eff_pace"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 14,
"popolo": 4
}
set_flags = {
"pace_mediata": true
}
unlock_lore = ["lore_pace_imperi"]
add_decisione_chiave = "mediato_pace"
add_to_log = ""
rapporti_civilta = {
"impero_sole": 20,
"lega_coste": 20
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_fonderia"]
script = ExtResource("eff")
stat_delta = {
"costruzione": 14,
"scienza": 6
}
set_flags = {
"fonderia_avviata": true
}
unlock_lore = ["lore_grande_fonderia"]
add_decisione_chiave = "avviato_fonderia"
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 1

[sub_resource type="Resource" id="opt_guerra"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Marciare contro l'Impero"
target_consigliere_id = "era2_calden"
effetto = SubResource("eff_guerra")
feedback_testo = "Calden leva gli eserciti verso il Sole calante. Il regno sceglie la spada. Il mondo brucerà, ma porterà il nostro nome."

[sub_resource type="Resource" id="opt_pace"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Mediare la pace"
target_consigliere_id = "era2_sereth"
effetto = SubResource("eff_pace")
feedback_testo = "Sereth siede tra l'Impero e la Lega e cuce una pace impossibile. Il regno diventa il centro, non il margine."

[sub_resource type="Resource" id="opt_fonderia"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Avviare la grande fonderia"
target_consigliere_id = "era2_lena"
effetto = SubResource("eff_fonderia")
feedback_testo = "Lena accende la grande fonderia. Fumo e ingranaggi anticipano un'era che il mondo non è pronto a vedere."

[resource]
script = ExtResource("dec")
id = "d_corte_08_destino"
era = 2
testo_consigliere = "Karro: il regno è al bivio. L'Impero del Sole vacilla, la Lega osserva, le macchine di Lena fremono. La prossima scelta deciderà che tipo di era lasceremo dietro di noi."
personaggio_id = "era2_karro"
opzioni = [SubResource("opt_guerra"), SubResource("opt_pace"), SubResource("opt_fonderia")]
tipo_decisione = "svolta"
