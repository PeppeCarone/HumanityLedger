target_consigliere_id = "era2_lena"
effetto = SubResource("eff_demolisci")
feedback_testo = "Lena abbatte il tempio e ne erige uno nuovo. Le pietre vecchie spariscono. Per un po', i sogni tacciono."

[resource]
script = ExtResource("dec")
id = "d_corte_07_tempio"
era = 2
testo_consigliere = "Iove: hanno trovato un tempio ai margini della città. Nessuno l'ha costruito, nessuno ricorda quando sia apparso - ed è identico all'Idolo del Fuoco della caverna. Cosa ne facciamo?"
personaggio_id = "era2_iove"
opzioni = [SubResource("opt_studia"), SubResource("opt_consacra"), SubResource("opt_demolisci")]
tipo_decisione = "mistero"
