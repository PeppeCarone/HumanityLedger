target_consigliere_id = "era2_iove"
effetto = SubResource("eff_studia")
feedback_testo = "Iove misura il tempio: è identico all'Idolo della caverna, pietra per pietra. Eppure nessuno l'ha costruito. La presenza ha lasciato un segno."

[sub_resource type="Resource" id="opt_consacra"]
script = ExtResource("opt")
strategia = ExtResource("s_decreto")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Consacralo all'ordine del regno"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_consacra")
feedback_testo = "Maren benedice il tempio e lo iscrive nelle leggi. Reso sacro e ufficiale, smette di fare domande. O così sembra."

[sub_resource type="Resource" id="opt_demolisci"]
script = ExtResource("opt")
