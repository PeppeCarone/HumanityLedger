[sub_resource type="Resource" id="opt_2"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Leggi il cielo per trovare altra acqua"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_2")
feedback_testo = "Lyssa segue il volo degli uccelli all'alba e indica un avvallamento tra le colline. Là trovano una pozza nascosta. \"L'acqua chiama l'acqua,\" dice. \"Basta ascoltare chi ha già bevuto.\""

[resource]
script = ExtResource("dec")
id = "d_acc_06_acqua"
era = 1
testo_consigliere = "La sorgente vicino all'accampamento si è fatta sottile, un filo d'acqua tra i sassi. Con il caldo che arriva non basterà per tutti. Possiamo muoverci ora, prima che diventi un problema di lance invece che di secchi. Da dove partiamo per non restare a secco?"
personaggio_id = "era1_tev"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "proposta_consigliere"
