[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Scava un pozzo fin dove l'acqua si nasconde"
target_consigliere_id = "era1_tev"
effetto = SubResource("eff_0")
feedback_testo = "Tev scende nella terra fino a dove il fango si fa freddo. Quando l'acqua sgorga, il popolo esulta come dopo una caccia. In fondo, è la stessa cosa: hanno strappato la vita alla terra."

