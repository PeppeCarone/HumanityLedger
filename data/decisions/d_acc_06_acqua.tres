[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_economico")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_economico")
label_text = "Raziona ogni sorso e fai scorta"
target_consigliere_id = "era1_vesha"
effetto = SubResource("eff_1")
feedback_testo = "Vesha mette un guardiano alla sorgente e conta i secchi due volte al giorno. \"L'acqua adesso vale più della carne,\" dice. La sete non uccide nessuno, ma nessuno la ringrazia."

