effetto = SubResource("eff_0")
feedback_testo = "Iove trasforma una taverna in spezieria e scompone il morbo come un metallo impuro. Il rimedio arriva tardi per molti, ma arriva. \"Ogni piaga,\" annota, \"è una domanda posta male.\""

