icona_drag = ExtResource("t_rivoluzionaria")
label_text = "Porta cure e pane in mezzo ai malati"
target_consigliere_id = "era2_karro"
effetto = SubResource("eff_2")
feedback_testo = "Karro entra nei quartieri bassi quando tutti ne scappano, e mezza piazza lo segue con erbe e pane. Qualcuno di loro non torna. Ma il popolo non dimentica chi è rimasto."

[resource]
script = ExtResource("dec")
id = "d_corte_17_peste"
era = 2
testo_consigliere = "Tre morti alla porta del fiume, dieci giorni fa. Ieri ventisette, e stamattina i carri non bastavano. Ho misurato il passo del morbo come misuro le stelle: raddoppia ogni quattro giorni, e non ha ancora toccato i quartieri alti. Le erbe amare che bruciano nei vicoli non fermeranno la proporzione. Come fermiamo la peste?"
personaggio_id = "era2_iove"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "catastrofe"
illustrazione_id = "plague"
