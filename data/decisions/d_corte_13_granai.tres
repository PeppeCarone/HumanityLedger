oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_spionaggio")
label_text = "Sottrai i convogli diretti all'Impero"
target_consigliere_id = "era2_saekh"
effetto = SubResource("eff_2")
feedback_testo = "Saekh non racconta come, e nessuno chiede. I carri arrivano di notte, senza insegne, pieni di grano con il marchio del Sole raschiato via. Il popolo mangia. Da est, prima o poi, qualcuno verrà a contare i carri."

[resource]
script = ExtResource("dec")
id = "d_corte_13_granai"
era = 2
testo_consigliere = "I conti sono questi: le piogge lunghe hanno marcito il raccolto, i granai sono a un terzo e i mercanti chiedono il triplo per il grano che resta. L'inverno non aspetta i nostri bilanci. Da dove prendiamo il pane che manca?"
personaggio_id = "era2_vorrik"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "catastrofe"
illustrazione_id = "crisi_economica"
