[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_rivoluzionaria")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_rivoluzionaria")
label_text = "Apri le riserve del regno alla piazza"
target_consigliere_id = "era2_karro"
effetto = SubResource("eff_1")
feedback_testo = "Karro spalanca i granai del regno e distribuisce con le sue mani, un sacco per famiglia, davanti a tutti. \"Il regno siete voi,\" grida. \"Quello che era suo era già vostro.\" La piazza non lo dimenticherà."

