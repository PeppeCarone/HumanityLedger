[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_economico")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_economico")
label_text = "Compra il grano della Lega a qualunque prezzo"
target_consigliere_id = "era2_vorrik"
effetto = SubResource("eff_0")
feedback_testo = "Vorrik firma il contratto con la mascella serrata: le navi della Lega scaricano grano per tutto l'autunno. \"Pago,\" dice. \"Ma che sia scritto: quando le parti si invertiranno, ricorderò il prezzo che hanno fatto.\""

