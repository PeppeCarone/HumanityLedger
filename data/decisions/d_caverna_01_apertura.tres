[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]

[sub_resource type="Resource" id="eff_scudo"]
script = ExtResource("eff")
stat_delta = {
"militare": 10
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_libro"]
script = ExtResource("eff")
stat_delta = {
"scienza": 10
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_pergamena"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 10
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_scudo"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Affila le lance per la caccia"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_scudo")
feedback_testo = "Brann pesa il bastone in mano, una volta, due. \"I sogni non sfamano,\" dice, e tutti gli si stringono attorno."

[sub_resource type="Resource" id="opt_libro"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Leggi i segni nella cenere"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_libro")
feedback_testo = "Lyssa traccia un cerchio nella cenere fredda. Le ombre sulla parete si muovono prima del fuoco."

[sub_resource type="Resource" id="opt_pergamena"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Tendi una mano ai vicini"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_pergamena")
feedback_testo = "Orm apre le mani vuote verso l'imbocco della caverna. \"Chi non minaccia,\" dice piano, \"può ancora scegliere gli amici.\""

[resource]
script = ExtResource("dec")
id = "d_caverna_01_apertura"
era = 1
testo_consigliere = "Stanotte ho sognato la pioggia battere su una pietra che non avevamo ancora posato. E un volto, chino su di noi, senza nome. Vengono giorni magri, spirito. Dove appoggiamo la prima forza del popolo?"
personaggio_id = "era1_lyssa"
opzioni = [SubResource("opt_scudo"), SubResource("opt_libro"), SubResource("opt_pergamena")]
tipo_decisione = "proposta_consigliere"
