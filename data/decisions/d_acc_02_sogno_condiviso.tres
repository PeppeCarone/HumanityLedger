[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]

[sub_resource type="Resource" id="eff_ascolta"]
script = ExtResource("eff")
stat_delta = {
"scienza": 12
}
set_flags = {
"ascolta_sogno_condiviso": true
}
unlock_lore = ["lore_sogno_condiviso"]
add_decisione_chiave = "ascolta_la_voce"
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_archivia"]
script = ExtResource("eff")
stat_delta = {
"legge": 10,
"popolo": 2
}
set_flags = {
"sogno_archiviato": true
}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_ignora"]
script = ExtResource("eff")
stat_delta = {
"militare": 6,
"popolo": 4
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_ascolta"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Da' ascolto alla voce sotto la pietra"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_ascolta")
feedback_testo = "Lyssa siede col vecchio Murr e insieme ridicono il sogno a una sola voce, senza inciampare. Quando tacciono, il fuoco si abbassa da solo, come ad ascoltare anche lui."

[sub_resource type="Resource" id="opt_archivia"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Incidilo tra le leggi e mettilo a tacere"
target_consigliere_id = "era1_murr"
effetto = SubResource("eff_archivia")
feedback_testo = "Murr incide il sogno sulla tavoletta delle regole, accanto a quelle dei padri. Messo in fila con le altre, smette di far paura. \"Ciò che ha un posto,\" mormora, \"non ti viene a cercare di notte.\""

[sub_resource type="Resource" id="opt_ignora"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Liquidalo: è soltanto la fame"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_ignora")
feedback_testo = "Brann scoppia a ridere e la tensione si spezza come un ramo secco. \"Due vecchi affamati sognano lo stesso osso. Grande mistero.\" Tutti tornano al lavoro, e va bene così. Quasi tutti."

[resource]
script = ExtResource("dec")
id = "d_acc_02_sogno_condiviso"
era = 1
testo_consigliere = "Murr non sogna da trent'anni. Stanotte ha sognato il mio sogno: lo stesso volto chino, senza nome, la stessa voce che sale da sotto la pietra. Parola per parola, come se l'avessimo dormito insieme. Non chiedermi cosa significa. Chiedimi cosa ne facciamo."
personaggio_id = "era1_lyssa"
opzioni = [SubResource("opt_ascolta"), SubResource("opt_archivia"), SubResource("opt_ignora")]
tipo_decisione = "mistero"
