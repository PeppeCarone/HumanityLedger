[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_decreto")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Incidi leggi e sentenze nella pietra"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_0")
feedback_testo = "Maren sceglie le cento sentenze che hanno retto il regno e le fa incidere nel granito dell'archivio. \"Le storie consolano,\" dice. \"Le leggi proteggono. Chi verrà dopo capirà chi eravamo da come giudicavamo.\""

