[resource]
script = ExtResource("dec")
id = "d_corte_02_voce_bosco"
era = 2
testo_consigliere = "Alla cena degli inviati uno straniero mi ha sussurrato, cortese come si porge un dono: 'un volto senza nome, una voce sotto la pietra'. Quando mi sono voltata non c'era più, e nessuna corte lo riconosce tra i propri. Iove giura di avere già sentito quelle parole, ere fa. Io tratto con gli imperi senza tremare; stanotte ho tremato. Come rispondiamo a questa voce?"
personaggio_id = "era2_sereth"
opzioni = [SubResource("opt_ascolta"), SubResource("opt_diceria"), SubResource("opt_scorta")]
tipo_decisione = "mistero"
