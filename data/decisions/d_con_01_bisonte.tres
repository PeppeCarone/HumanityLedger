[gd_resource type="Resource" script_class="Decision" load_steps=17 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]
[ext_resource type="Resource" path="res://data/strategie/spionaggio.tres" id="s_spionaggio"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/spionaggio.png" id="t_spionaggio"]

[sub_resource type="Resource" id="eff_tratta"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 12,
"popolo": 3
}
set_flags = {
"bisonte_patto": true
}
unlock_lore = ["lore_clan_bisonte"]
add_decisione_chiave = "patto_bisonte"
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": 25
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_lance"]
script = ExtResource("eff")
stat_delta = {
"militare": 12,
"popolo": -2
}
set_flags = {
"bisonte_ostile": true
}
unlock_lore = ["lore_clan_bisonte"]
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": -30
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_spia"]
script = ExtResource("eff")
stat_delta = {
"spionaggio": 12,
"scienza": 4
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": -5
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_tratta"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Siedi con lui e offrigli il sale"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_tratta")
feedback_testo = "Orm divide il sale con l'inviato e parla a lungo, piano. L'uomo riparte annuendo. \"Le lance restano abbassate,\" dice Orm. \"Finché conviene a entrambi.\""

[sub_resource type="Resource" id="opt_lance"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Schiera gli uomini davanti a lui"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_lance")
feedback_testo = "Brann mette in fila ogni uomo che regge una lancia. L'inviato li conta con gli occhi, sorride appena, e se ne va senza una parola. Ha visto tutto quello che voleva vedere."

[sub_resource type="Resource" id="opt_spia"]
script = ExtResource("opt")
strategia = ExtResource("s_spionaggio")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_spionaggio")
label_text = "Annuisci, poi seguilo nell'ombra"
target_consigliere_id = "era1_kael"
effetto = SubResource("eff_spia")
feedback_testo = "Kael lo lascia andare contento, poi gli sta dietro fino al fiume. Tende: quaranta. Lance: il doppio delle bocche. Torna e non promette niente. \"Adesso sappiamo. E loro non sanno che sappiamo.\""

[resource]
script = ExtResource("dec")
id = "d_con_01_bisonte"
era = 1
testo_consigliere = "Un inviato del Clan del Bisonte è alle capanne. Uno solo, disarmato. Dietro di lui: tre volte le nostre bocche, e il fiume in pugno. Dice di voler parlare. Chi manda un solo uomo, sa di poterne perdere uno. Come lo accogliamo?"
personaggio_id = "era1_kael"
opzioni = [SubResource("opt_tratta"), SubResource("opt_lance"), SubResource("opt_spia")]
tipo_decisione = "incontro"
illustrazione_id = "rebellion"
