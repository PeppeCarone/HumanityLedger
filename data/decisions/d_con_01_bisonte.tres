[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]

[sub_resource type="Resource" id="eff_tratta"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 12,
"popolo": 3
}
set_flags = {
"bisonte_patto": true
}
unlock_lore = ["lore_clan_bisonte"]
add_decisione_chiave = "patto_bisonte"
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": 25
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_lance"]
script = ExtResource("eff")
stat_delta = {
"militare": 12,
"popolo": -2
}
set_flags = {
"bisonte_ostile": true
}
unlock_lore = ["lore_clan_bisonte"]
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": -30
}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_spia"]
script = ExtResource("eff")
stat_delta = {
"spionaggio": 12,
"scienza": 4
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"clan_bisonte": -5
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_tratta"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Offrire un patto"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_tratta")
feedback_testo = "Orm scambia sale e parole con l'inviato. Il Clan del Bisonte abbassa le lance, per ora."

[sub_resource type="Resource" id="opt_lance"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Mostrare le lance"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_lance")
feedback_testo = "Brann schiera gli uomini in fila. L'inviato del Bisonte se ne va in silenzio. Tornerà con più di parole."

[sub_resource type="Resource" id="opt_spia"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Seguirne le tracce"
target_consigliere_id = "era1_kael"
effetto = SubResource("eff_spia")
feedback_testo = "Kael segue l'inviato fino al fiume. Conta le tende, le bocche, le lance. Sapere è già mezza difesa."

[resource]
script = ExtResource("dec")
id = "d_con_01_bisonte"
era = 1
testo_consigliere = "Kael: un inviato del Clan del Bisonte è alle capanne. Sono più numerosi di noi e occupano il fiume. Vuole parlare. Come lo riceviamo?"
personaggio_id = "era1_kael"
opzioni = [SubResource("opt_tratta"), SubResource("opt_lance"), SubResource("opt_spia")]
tipo_decisione = "incontro"
illustrazione_id = "rebellion"
