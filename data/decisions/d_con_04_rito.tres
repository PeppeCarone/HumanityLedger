[sub_resource type="Resource" id="opt_2"]
script = ExtResource("opt")
strategia = ExtResource("s_decreto")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Fissa il rito nelle regole degli avi"
target_consigliere_id = "era1_murr"
effetto = SubResource("eff_2")
feedback_testo = "Murr stabilisce ogni gesto del rito come legge: chi sta davanti, chi porta il fuoco, quando si tace. Tutto è ordinato, tutto è giusto. E qualcosa, nel troppo ordine, si raffredda."

[resource]
script = ExtResource("dec")
id = "d_con_04_rito"
era = 1
testo_consigliere = "Prima di alzare l'Idolo il popolo vuole un rito che lo leghi alla pietra. Ma Lyssa dice che la pittura sulla parete è cambiata ancora: il volto senza nome ora guarda dritto al punto dove sorgerà l'Idolo. Facciamo comunque il rito? E in che forma?"
personaggio_id = "era1_aru"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "mistero"
illustrazione_id = "era1_trance"
