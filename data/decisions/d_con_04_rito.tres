[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Lascia che Lyssa interroghi la pittura"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_1")
feedback_testo = "Lyssa appoggia la fronte alla parete dipinta e resta immobile a lungo. Quando si stacca, ha gli occhi lucidi. \"Non chiede di essere temuto,\" dice piano. \"Chiede di essere ricordato. E noi stiamo per dargli una pietra in cui abitare.\""

