[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_rivoluzionaria")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_rivoluzionaria")
label_text = "Guida un canto che unisca tutte le voci"
target_consigliere_id = "era1_aru"
effetto = SubResource("eff_0")
feedback_testo = "Aru intona una nota sola e il popolo la raccoglie, voce su voce, finché la caverna stessa sembra cantare. Per un istante nessuno ha più freddo, nessuno ha più paura. Poi il canto tace, e sulla parete il volto sembra sorridere."

