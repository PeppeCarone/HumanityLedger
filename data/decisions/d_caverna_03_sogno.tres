[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Resource" path="res://data/strategie/ascia.tres" id="s_ascia"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/ascia.png" id="t_ascia"]

[sub_resource type="Resource" id="eff_tradizione"]
script = ExtResource("eff")
stat_delta = {
"legge": 10,
"militare": 3
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_visione"]
script = ExtResource("eff")
stat_delta = {
"scienza": 15
}
set_flags = {
"sogno_accolto": true
}
unlock_lore = ["lore_sogno_condiviso"]
add_decisione_chiave = "sogno_accolto"
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_altare"]
script = ExtResource("eff")
stat_delta = {
"costruzione": 12,
"popolo": 5
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_tradizione"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Torna alle regole degli avi"
target_consigliere_id = "era1_murr"
effetto = SubResource("eff_tradizione")
feedback_testo = "Murr ripete la formula di sempre. La caverna resta uguale a se stessa."

[sub_resource type="Resource" id="opt_visione"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Affidati alla visione del sogno"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_visione")
feedback_testo = "Lyssa fissa la fiamma. Qualcosa la fissa di rimando. Il popolo trattiene il respiro."

[sub_resource type="Resource" id="opt_altare"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Erigi un altare al presagio"
target_consigliere_id = "era1_tev"
effetto = SubResource("eff_altare")
feedback_testo = "Tev solleva la pietra. Per la prima volta il clan ha un centro che non è solo il fuoco."

[resource]
script = ExtResource("dec")
id = "d_caverna_03_sogno"
era = 1
testo_consigliere = "Murr: il sogno bussa di nuovo. Le ossa antiche dicono una cosa, il fuoco un'altra. A chi diamo retta prima di lasciare la caverna?"
personaggio_id = "era1_murr"
opzioni = [SubResource("opt_tradizione"), SubResource("opt_visione"), SubResource("opt_altare")]
tipo_decisione = "proposta_consigliere"
