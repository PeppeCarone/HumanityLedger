effetto = SubResource("eff_1")
feedback_testo = "Kael si siede accanto al ferito e aspetta. Niente minacce: domande corte, silenzi lunghi. Quando l'uomo torna ai suoi, noi sappiamo quanti sono e cosa temono. Lui non sa di averlo detto."

