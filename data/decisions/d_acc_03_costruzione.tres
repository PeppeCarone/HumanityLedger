[sub_resource type="Resource" id="opt_capanna"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Alza capanne di pietra"
target_consigliere_id = "era1_tev"
effetto = SubResource("eff_capanna")
feedback_testo = "Tev alza il primo muro fuori dalla caverna. Per la prima volta il popolo costruisce invece di rifugiarsi."

[sub_resource type="Resource" id="opt_astri"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Orienta il campo con gli astri"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_astri")
feedback_testo = "Lyssa allinea le capanne alle stelle. Il villaggio nasce con un disegno che nessuno sa spiegare del tutto."

[sub_resource type="Resource" id="opt_scorte"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Costruisci prima il magazzino"
target_consigliere_id = "era1_vesha"
effetto = SubResource("eff_scorte")
feedback_testo = "Vesha pretende un deposito prima delle case. Pance piene oggi, dice, o non ci sarà nessun domani da costruire."

[resource]
script = ExtResource("dec")
id = "d_acc_03_costruzione"
era = 1
testo_consigliere = "Tev: la terra qui regge il peso. Possiamo costruire qualcosa che resti più di noi. Da dove partiamo a fondare l'accampamento?"
personaggio_id = "era1_tev"
opzioni = [SubResource("opt_capanna"), SubResource("opt_astri"), SubResource("opt_scorte")]
tipo_decisione = "proposta_consigliere"
