[sub_resource type="Resource" id="opt_mura"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Fondare sulle mura"
target_consigliere_id = "era2_lena"
effetto = SubResource("eff_mura")
feedback_testo = "Lena fonda il regno sulla pietra: prima la difesa, poi tutto il resto. La città cresce verso l'alto."

[sub_resource type="Resource" id="opt_piazza"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Fondare sulla piazza"
target_consigliere_id = "era2_karro"
effetto = SubResource("eff_piazza")
feedback_testo = "Karro mette la voce del popolo al centro. La piazza pulsa, ma chi la guida non sempre la controlla."

[sub_resource type="Resource" id="opt_accademia"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Fondare sul sapere"
target_consigliere_id = "era2_iove"
effetto = SubResource("eff_accademia")
feedback_testo = "Iove apre una casa di stelle e metalli. Il regno comincia a chiedersi il perché delle cose, non solo il come."

[resource]
script = ExtResource("dec")
id = "d_corte_03_fondazione"
era = 2
testo_consigliere = "Karro: il popolo guarda al nuovo consiglio e chiede su cosa fonderemo il regno. Mura, piazza o sapere: la prima pietra dirà chi siamo."
personaggio_id = "era2_karro"
opzioni = [SubResource("opt_mura"), SubResource("opt_piazza"), SubResource("opt_accademia")]
tipo_decisione = "svolta"
illustrazione_id = "scienza"
