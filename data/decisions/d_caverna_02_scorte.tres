[sub_resource type="Resource" id="eff_trattare"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 15,
"tesoro": 5
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = "accolto_popolo_nebbie"
