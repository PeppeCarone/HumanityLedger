[gd_resource type="Resource" script_class="Decision" load_steps=15 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/scudo.tres" id="s_scudo"]
[ext_resource type="Resource" path="res://data/strategie/libro.tres" id="s_libro"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/scudo.png" id="t_scudo"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/libro.png" id="t_libro"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]

[sub_resource type="Resource" id="eff_razionare"]
script = ExtResource("eff")
stat_delta = {
"militare": 5,
"popolo": -3
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_studio"]
script = ExtResource("eff")
stat_delta = {
"scienza": 8,
"popolo": 3
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="eff_trattare"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 15,
"tesoro": 5
}
set_flags = {}
unlock_lore = []
add_decisione_chiave = "accolto_popolo_nebbie"
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_razionare"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Imponi razioni a mano dura"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_razionare")
feedback_testo = "Brann si siede accanto alla cesta e non si muove. Nessuno allunga la mano. Nessuno lo ringrazia."

[sub_resource type="Resource" id="opt_studio"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Cerca cibo oltre le colline note"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_studio")
feedback_testo = "Lyssa indica colline che nessuno ha mai battuto. \"La terra nutre,\" mormora, \"chi ha il coraggio di guardarla negli occhi.\""

[sub_resource type="Resource" id="opt_trattare"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Baratta col Popolo delle Nebbie"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_trattare")
feedback_testo = "Orm scende alla bruma con pietre dipinte. Torna con sale, e con un'osso intagliato che nessuno gli ha visto chiedere."

[resource]
script = ExtResource("dec")
id = "d_caverna_02_scorte"
era = 1
testo_consigliere = "Ho contato di nuovo. Sette pelli, sei lune di freddo davanti, e già si vede il fondo della cesta. I numeri non mentono come i sogni. Cosa diciamo alle pance, quando il fondo arriva?"
personaggio_id = "era1_vesha"
opzioni = [SubResource("opt_razionare"), SubResource("opt_studio"), SubResource("opt_trattare")]
tipo_decisione = "proposta_consigliere"
