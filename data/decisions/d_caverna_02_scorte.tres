rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_razionare"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Razionare con la forza"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_razionare")
feedback_testo = "Brann sorveglia il fuoco. Le bocche si chiudono."

[sub_resource type="Resource" id="opt_studio"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Studiare il territorio"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_studio")
feedback_testo = "Lyssa indica colline nuove. Le scorte trovano un volto diverso."

[sub_resource type="Resource" id="opt_trattare"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Trattare con le Nebbie"
target_consigliere_id = "era1_orm"
effetto = SubResource("eff_trattare")
feedback_testo = "Orm porta segni di pietra agli stranieri. Tornano con sale e silenzio."

[resource]
script = ExtResource("dec")
id = "d_caverna_02_scorte"
era = 1
testo_consigliere = "Vesha: sette pelli, sei lune. Il fondo della cesta è vicino. Decidiamo prima che il fuoco lo decida."
personaggio_id = "era1_vesha"
opzioni = [SubResource("opt_razionare"), SubResource("opt_studio"), SubResource("opt_trattare")]
tipo_decisione = "proposta_consigliere"
