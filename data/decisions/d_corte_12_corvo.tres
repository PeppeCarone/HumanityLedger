[gd_resource type="Resource" script_class="Decision" load_steps=16 format=3]

[ext_resource type="Script" path="res://scripts/data/decision.gd" id="dec"]
[ext_resource type="Script" path="res://scripts/data/decision_option.gd" id="opt"]
[ext_resource type="Script" path="res://scripts/data/effect.gd" id="eff"]
[ext_resource type="Resource" path="res://data/strategie/spionaggio.tres" id="s_spionaggio"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/spionaggio.png" id="t_spionaggio"]
[ext_resource type="Resource" path="res://data/strategie/decreto.tres" id="s_decreto"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/decreto.png" id="t_decreto"]
[ext_resource type="Resource" path="res://data/strategie/pergamena.tres" id="s_pergamena"]
[ext_resource type="Texture2D" path="res://Assets/art/strategie/pergamena.png" id="t_pergamena"]

[sub_resource type="Resource" id="eff_0"]
script = ExtResource("eff")
stat_delta = {
"spionaggio": 13,
"militare": 2
}
set_flags = {
"corvo_doppio": true
}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_spionaggio")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_spionaggio")
label_text = "Rigiralo e rimandalo a casa con notizie false"
target_consigliere_id = "era2_saekh"
effetto = SubResource("eff_0")
feedback_testo = "Saekh parla con il prigioniero una notte intera, da solo. All'alba l'uomo riparte verso est, con il suo rotolo... ridisegnato. \"Ora le nostre mura,\" sussurra Saekh, \"sono alte il doppio. Sulla carta.\""

[sub_resource type="Resource" id="eff_1"]
script = ExtResource("eff")
stat_delta = {
"legge": 12,
"diplomazia": -3
}
set_flags = {}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"impero_sole": -8
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_decreto")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Processalo alla luce, davanti al regno"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_1")
feedback_testo = "Maren istruisce il processo nella piazza grande, atto per atto, senza alzare mai la voce. La sentenza è esilio. Il regno impara che la legge vale anche per le ombre. L'Impero impara che li prendiamo."

[sub_resource type="Resource" id="eff_2"]
script = ExtResource("eff")
stat_delta = {
"diplomazia": 12
}
set_flags = {}
unlock_lore = []
unlock_eventi = []
add_decisione_chiave = ""
add_to_log = ""
rapporti_civilta = {
"impero_sole": 8
}
popolazione_delta = 0

[sub_resource type="Resource" id="opt_2"]
script = ExtResource("opt")
strategia = ExtResource("s_pergamena")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_pergamena")
label_text = "Restituiscilo all'Impero con una scorta d'onore"
target_consigliere_id = "era2_sereth"
effetto = SubResource("eff_2")
feedback_testo = "Sereth riconsegna l'uomo al confine con doni e una lettera squisita che non nomina mai la parola spia. L'Impero capisce tre cose: sappiamo, non temiamo, e preferiamo parlare."

[resource]
script = ExtResource("dec")
id = "d_corte_12_corvo"
era = 2
testo_consigliere = "Un uomo. Preso stanotte, sulle mura. Copiava i camminamenti su un rotolo... e nella fodera, cucito, il sigillo del Sole. Nessuno sa che lo abbiamo noi. Nemmeno l'Impero. Per ora. Cosa ne facciamo del corvo dell'Impero?"
personaggio_id = "era2_saekh"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "proposta_consigliere"
