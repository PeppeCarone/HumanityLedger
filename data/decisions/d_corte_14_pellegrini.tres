[sub_resource type="Resource" id="opt_1"]
script = ExtResource("opt")
strategia = ExtResource("s_decreto")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_decreto")
label_text = "Vieta i raduni dopo il tramonto"
target_consigliere_id = "era2_maren"
effetto = SubResource("eff_1")
feedback_testo = "Maren pesa il divieto parola per parola e lo fa affiggere alle porte. La notte torna silenziosa e ordinata. Ma nelle case, sottovoce, con le imposte chiuse, il canto continua."

