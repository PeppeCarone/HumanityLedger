[sub_resource type="Resource" id="opt_2"]
script = ExtResource("opt")
strategia = ExtResource("s_rivoluzionaria")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_rivoluzionaria")
label_text = "Scendi in piazza e canta con loro"
target_consigliere_id = "era2_karro"
effetto = SubResource("eff_2")
feedback_testo = "Karro canta con i pellegrini fino all'alba, la voce roca in mezzo alle altre. \"Non so cosa dica il canto,\" ammette poi. \"Ma so che la piazza non era mai stata così unita. E questo, di solito, lo so usare.\""

[resource]
script = ExtResource("dec")
id = "d_corte_14_pellegrini"
era = 2
testo_consigliere = "Ogni notte la gente si raduna al tempio che nessuno ha costruito. Cantano una nenia che nessuno ricorda di avere imparato, e i bambini la cantano meglio dei vecchi. Ho cercato nei codici: la legge non ha una riga su questo. Cosa facciamo dei pellegrini del tempio?"
personaggio_id = "era2_maren"
opzioni = [SubResource("opt_0"), SubResource("opt_1"), SubResource("opt_2")]
tipo_decisione = "mistero"
