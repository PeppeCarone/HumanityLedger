[sub_resource type="Resource" id="opt_0"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Trascrivi il canto e cercane la misura"
target_consigliere_id = "era2_iove"
effetto = SubResource("eff_0")
feedback_testo = "Iove annota il canto in cifre e intervalli, nota dopo nota, e impallidisce sulle proporzioni. \"Le voci salgono come le stelle d'inverno,\" dice. \"Esatte. Questa melodia non è nata in una gola umana.\""

[sub_resource type="Resource" id="eff_1"]
script = ExtResource("eff")
