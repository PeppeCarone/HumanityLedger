[sub_resource type="Resource" id="opt_riparo"]
script = ExtResource("opt")
strategia = ExtResource("s_ascia")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_ascia")
label_text = "Scava in fondo alla roccia"
target_consigliere_id = "era1_tev"
effetto = SubResource("eff_riparo")
feedback_testo = "Tev apre la roccia viva con le unghie spaccate e l'ascia. Il clan si schiaccia là dove la pietra trattiene il poco caldo. Al settimo giorno si contano, e ci sono tutti."

[sub_resource type="Resource" id="opt_caccia"]
script = ExtResource("opt")
strategia = ExtResource("s_scudo")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_scudo")
label_text = "Manda i cacciatori nella tormenta"
target_consigliere_id = "era1_brann"
effetto = SubResource("eff_caccia")
feedback_testo = "Brann esce nel bianco con sei uomini e torna con quattro e una carcassa di cervo. Mangiano tutti. Per due posti vuoti attorno al fuoco, nessuno mangia parlando."

[sub_resource type="Resource" id="opt_sapienza"]
script = ExtResource("opt")
strategia = ExtResource("s_libro")
oggetto_drag = "icona_strategia"
icona_drag = ExtResource("t_libro")
label_text = "Conta le notti e dosa tutto"
target_consigliere_id = "era1_lyssa"
effetto = SubResource("eff_sapienza")
feedback_testo = "Lyssa segna le notti con tacche sul bastone e divide il cibo in bocconi che sembrano un insulto alla fame. Ma al bastone le tacche finiscono, e il sole torna. Aveva contato giusto."

[resource]
script = ExtResource("dec")
id = "d_caverna_05_inverno"
era = 1
testo_consigliere = "Le storie vecchie hanno un nome per questo: il Grande Freddo. Le ho sentite da bambino, non credevo di vederlo. Sette notti che il sole non sorge, e il fuoco non arriva più alle dita. Il popolo guarda noi. Cosa gli diciamo di fare?"
personaggio_id = "era1_murr"
opzioni = [SubResource("opt_riparo"), SubResource("opt_caccia"), SubResource("opt_sapienza")]
tipo_decisione = "catastrofe"
illustrazione_id = "era1_inverno"
